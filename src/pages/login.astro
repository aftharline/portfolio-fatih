---
// Simplified Login Logic
export const prerender = false; // <--- Tambahkan ini
import '../styles/global.css';
---
<body class="bg-zinc-950 text-white p-10">
  <form id="login-form" class="max-w-sm mx-auto bg-zinc-900 p-6 rounded-xl border border-white/10">
    <h2 class="text-xl font-bold mb-4">Login Admin</h2>
    <input type="email" id="email" placeholder="Email" class="w-full bg-zinc-950 p-2 mb-3 border border-white/10 rounded" />
    <input type="password" id="password" placeholder="Password" class="w-full bg-zinc-950 p-2 mb-4 border border-white/10 rounded" />
    <button type="submit" class="w-full bg-white text-black py-2 rounded font-bold">Masuk</button>
  </form>

  <script>
    import { createClient } from '@supabase/supabase-js';
    const supabase = createClient(import.meta.env.PUBLIC_SUPABASE_URL, import.meta.env.PUBLIC_SUPABASE_ANON_KEY);
    
document.getElementById('login-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;
    
    const { error } = await supabase.auth.signInWithPassword({ email, password });

    if (error) {
      alert("Gagal login: " + error.message);
    } else {
      // Login sukses, pindah ke admin
      window.location.href = '/admin';
    }
  });
  </script>
</body>