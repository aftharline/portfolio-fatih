    <!-- ============================================================
         SCRIPTS
    ============================================================ -->
    <script>
      document.addEventListener('astro:page-load', () => {

        const qs  = (s: string) => document.querySelector(s);
        const qsa = (s: string) => document.querySelectorAll(s);
        const isMobile = () => window.innerWidth < 768;
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        // ── 1. SCROLL PROGRESS ────────────────────────────────────
        const progressBar = qs('#scroll-progress') as HTMLElement;
        if (progressBar) {
          const update = () => {
            const max = document.documentElement.scrollHeight - window.innerHeight;
            progressBar.style.width = max > 0 ? `${(window.scrollY / max) * 100}%` : '0%';
          };
          window.addEventListener('scroll', update, { passive: true });
          update();
        }

        // ── 2. HEADER scroll state ────────────────────────────────
        const siteHeader = qs('#site-header') as HTMLElement;
        if (siteHeader) {
          const onScroll = () => siteHeader.classList.toggle('scrolled', window.scrollY > 40);
          window.addEventListener('scroll', onScroll, { passive: true });
          onScroll();
        }

        // ── 3. REVEAL OBSERVER ────────────────────────────────────
        const revealObs = new IntersectionObserver(
          entries => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in-view'); revealObs.unobserve(e.target); } }),
          { rootMargin: '0px 0px -60px 0px', threshold: 0.1 }
        );
        qsa('.reveal-up, .reveal-right, .line-draw').forEach(el => revealObs.observe(el));

        // ── 4. DOT NAV ────────────────────────────────────────────
        const dots     = qsa('.dot-nav-item');
        const sections = qsa('.project-section');
        if (dots.length && sections.length) {
          // Offset scroll: navbar (56px) + filter nav (~48px) + extra 8px
          const SCROLL_OFFSET = 56 + 48 + 8;
          dots.forEach((dot, i) => dot.addEventListener('click', () => {
            const section = sections[i] as HTMLElement | undefined;
            if (!section) return;
            const y = section.getBoundingClientRect().top + window.scrollY - SCROLL_OFFSET;
            window.scrollTo({ top: y, behavior: 'smooth' });
          }));
          const dotObs = new IntersectionObserver(
            entries => entries.forEach(e => {
              const idx = parseInt((e.target as HTMLElement).dataset.projectIndex || '0');
              if (e.isIntersecting) { dots.forEach(d => d.classList.remove('active')); dots[idx]?.classList.add('active'); }
            }),
            { rootMargin: '-40% 0px -40% 0px', threshold: 0 }
          );
          sections.forEach(s => dotObs.observe(s));
        }

        // ── 5. FILTER — dengan auto-scroll pill & glow state ─────
        const filterBtns = qsa('.filter-btn') as NodeListOf<HTMLElement>;
        const filterNav  = qs('#filter-nav') as HTMLElement;

        // Scroll active pill ke tengah viewport filter nav (mobile)
        const scrollBtnIntoView = (btn: HTMLElement) => {
          const track = qs('#filter-nav-track') as HTMLElement;
          if (!track) return;
          const btnLeft   = btn.offsetLeft;
          const btnWidth  = btn.offsetWidth;
          const trackW    = track.clientWidth;
          const targetScroll = btnLeft - (trackW / 2) + (btnWidth / 2);
          track.scrollTo({ left: targetScroll, behavior: 'smooth' });
        };

        const setActiveFilter = (targetBtn: HTMLElement) => {
          filterBtns.forEach(b => b.setAttribute('data-active', 'false'));
          targetBtn.setAttribute('data-active', 'true');
          scrollBtnIntoView(targetBtn);
          const filter = targetBtn.getAttribute('data-filter');
          (qsa('.project-section') as NodeListOf<HTMLElement>).forEach(s => {
            s.style.display = (filter === 'All' || s.getAttribute('data-category') === filter) ? 'flex' : 'none';
          });
        };

        filterBtns.forEach(btn => btn.addEventListener('click', () => setActiveFilter(btn)));

        // Init: pastikan "All" ter-scroll ke view
        const initActive = qs('.filter-btn[data-active="true"]') as HTMLElement | null;
        if (initActive) requestAnimationFrame(() => scrollBtnIntoView(initActive));

        // ── 6. PARALLAX (desktop, rAF-throttled) ─────────────────
        if (!isMobile() && !prefersReducedMotion) {
          const parallaxEls = qsa('[data-parallax]') as NodeListOf<HTMLElement>;
          let ticking = false;
          const doParallax = () => {
            parallaxEls.forEach(el => {
              const sticky = el.closest('.sticky');
              if (!sticky) return;
              const rect = sticky.getBoundingClientRect();
              el.style.transform = `translate3d(0,${(-rect.top / window.innerHeight) * 30}px,0)`;
            });
            ticking = false;
          };
          window.addEventListener('scroll', () => { if (!ticking) { requestAnimationFrame(doParallax); ticking = true; } }, { passive: true });
        }

        // ── 7. MUSIC ──────────────────────────────────────────────
        const bgMusic     = qs('#bg-music') as HTMLAudioElement;
        const musicToggle = qs('#music-toggle') as HTMLButtonElement;
        const iconPlay    = qs('#music-icon-play');
        const iconPause   = qs('#music-icon-pause');
        if (musicToggle && bgMusic) {
          bgMusic.volume = 0.25;
          let playing = false;
          musicToggle.addEventListener('click', () => {
            if (playing) {
              bgMusic.pause();
              iconPause?.classList.add('hidden'); iconPlay?.classList.remove('hidden');
              musicToggle.classList.remove('bg-white', 'text-black');
            } else {
              bgMusic.play().catch(() => {});
              iconPlay?.classList.add('hidden'); iconPause?.classList.remove('hidden');
              musicToggle.classList.add('bg-white', 'text-black');
            }
            playing = !playing;
          });
        }

        // ── 8. BACK TO TOP ────────────────────────────────────────
        const btt = qs('#back-to-top') as HTMLButtonElement;
        if (btt) {
          const toggleBtt = () => btt.classList.toggle('visible', window.scrollY > 400);
          window.addEventListener('scroll', toggleBtt, { passive: true });
          btt.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
          toggleBtt();
        }

        // ── 9. LIGHTBOX ───────────────────────────────────────────
        const lightbox = qs('#lightbox') as HTMLElement;
        if (lightbox) {
          const lbImg    = qs('#lightbox-img') as HTMLImageElement;
          const zoomWrap = qs('#img-zoom-wrapper') as HTMLElement;
          const counter  = qs('#lightbox-counter') as HTMLElement;
          const closeBtn = qs('#close-lightbox') as HTMLButtonElement;
          const prevBtn  = qs('#prev-btn') as HTMLButtonElement;
          const nextBtn  = qs('#next-btn') as HTMLButtonElement;
          const btnZIn   = qs('#zoom-in') as HTMLButtonElement;
          const btnZOut  = qs('#zoom-out') as HTMLButtonElement;
          const btnZRst  = qs('#zoom-reset') as HTMLButtonElement;
          const zoomInd  = qs('#zoom-indicator') as HTMLElement;

          let imgs: string[] = [];
          let idx = 0;
          let zoom = 1;

          const applyZoom = () => { zoomWrap.style.transform = `scale(${zoom})`; zoomInd.textContent = `${Math.round(zoom * 100)}%`; };
          const resetZoom = () => { zoom = 1; applyZoom(); };
          const setImg = () => {
            lbImg.src = imgs[idx];
            counter.textContent = `${idx + 1} / ${imgs.length}`;
            resetZoom();
            const single = imgs.length <= 1;
            prevBtn.classList.toggle('hidden', single);
            nextBtn.classList.toggle('hidden', single);
          };
          const open = (images: string[], startIdx: number) => {
            imgs = images; idx = startIdx;
            lightbox.classList.remove('hidden'); lightbox.classList.add('flex');
            document.body.style.overflow = 'hidden';
            setImg(); closeBtn.focus();
          };
          const close = () => {
            lightbox.classList.add('hidden'); lightbox.classList.remove('flex');
            document.body.style.overflow = ''; resetZoom();
          };

          // Project image clicks (lightbox gets ALL images via data-images)
          document.getElementById('projects-container')?.addEventListener('click', e => {
            const target = (e.target as HTMLElement).closest('.project-image') as HTMLImageElement | null;
            if (!target) return;
            open(JSON.parse(target.dataset.images!), parseInt(target.dataset.index!));
          });

          // "See all photos" button
          document.getElementById('projects-container')?.addEventListener('click', e => {
            const btn = (e.target as HTMLElement).closest('[data-open-all-images]') as HTMLElement | null;
            if (!btn) return;
            open(JSON.parse(btn.dataset.openAllImages!), 0);
          });

          nextBtn.addEventListener('click', e => { e.stopPropagation(); idx = (idx + 1) % imgs.length; setImg(); });
          prevBtn.addEventListener('click', e => { e.stopPropagation(); idx = (idx - 1 + imgs.length) % imgs.length; setImg(); });
          closeBtn.addEventListener('click', close);
          lightbox.addEventListener('click', e => { if (e.target === lightbox || (e.target as HTMLElement).classList.contains('lightbox-bg')) close(); });

          btnZIn.addEventListener('click',  e => { e.stopPropagation(); zoom = Math.min(zoom + 0.25, 3.5); applyZoom(); });
          btnZOut.addEventListener('click', e => { e.stopPropagation(); zoom = Math.max(zoom - 0.25, 0.5); applyZoom(); });
          btnZRst.addEventListener('click', e => { e.stopPropagation(); resetZoom(); });

          // Touch swipe
          let txStart = 0;
          lightbox.addEventListener('touchstart', e => { txStart = e.touches[0].clientX; }, { passive: true });
          lightbox.addEventListener('touchend', e => {
            const dx = e.changedTouches[0].clientX - txStart;
            if (Math.abs(dx) > 60 && imgs.length > 1) dx < 0 ? nextBtn.click() : prevBtn.click();
          }, { passive: true });

          document.addEventListener('keydown', e => {
            if (lightbox.classList.contains('hidden')) return;
            if (e.key === 'Escape') close();
            if (e.key === 'ArrowRight') nextBtn.click();
            if (e.key === 'ArrowLeft') prevBtn.click();
            if (e.key === '=' || e.key === '+') btnZIn.click();
            if (e.key === '-') btnZOut.click();
          });
        }

        // ── 10. WA FORM ───────────────────────────────────────────
        const waForm = qs('#wa-form') as HTMLFormElement;
        if (waForm) {
          waForm.addEventListener('submit', e => {
            e.preventDefault();
            const name    = (qs('#wa-name') as HTMLInputElement).value.trim();
            const topic   = (qs('#wa-topic') as HTMLInputElement).value.trim();
            const message = (qs('#wa-message') as HTMLTextAreaElement).value.trim();
            if (!name || !topic || !message) return;
            const text = `Halo Fatih, saya ${name}.\n\nSaya mau ngobrolin soal: *${topic}*\n\n${message}`;
            window.open(`https://wa.me/6285707109853?text=${encodeURIComponent(text)}`, '_blank', 'noopener');
          });
        }

        // ── 11. CROSSHAIR (desktop only) ──────────────────────────
        if (isMobile()) return;
        const chH = qs('#crosshair-h') as HTMLElement;
        const chV = qs('#crosshair-v') as HTMLElement;
        const coords = qs('#cursor-coords') as HTMLElement;
        if (!chH || !chV || !coords) return;

        let mX = window.innerWidth / 2, mY = window.innerHeight / 2;
        let cX = mX, cY = mY;
        let chVisible = false;

        window.addEventListener('mousemove', e => {
          mX = e.clientX; mY = e.clientY;
          if (!chVisible) { chH.style.opacity='1'; chV.style.opacity='1'; coords.style.opacity='1'; chVisible = true; }
        }, { passive: true });
        document.addEventListener('mouseleave', () => {
          chH.style.opacity='0'; chV.style.opacity='0'; coords.style.opacity='0'; chVisible = false;
        });

        const lerp = (a: number, b: number, t: number) => a + (b - a) * t;
        const animCH = () => {
          cX = lerp(cX, mX, 0.12); cY = lerp(cY, mY, 0.12);
          chH.style.transform = `translate3d(0,${cY}px,0)`;
          chV.style.transform = `translate3d(${cX}px,0,0)`;
          coords.style.transform = `translate3d(${cX + 14}px,${cY + 14}px,0)`;
          coords.textContent = `X:${Math.round(cX)} // Y:${Math.round(cY)}`;
          requestAnimationFrame(animCH);
        };
        requestAnimationFrame(animCH);

      });
    </script>

  </body>
</html>
