    <script>
      let _raf = 0, _clean: Array<() => void> = [];
      function init() {
        cancelAnimationFrame(_raf);
        _clean.forEach(f => f());
        _clean = [];
        const $ = (s: string) => document.querySelector(s);
        const $$ = (s: string) => document.querySelectorAll(s);

        const pl = $('#preloader');
        if (pl) { if (document.readyState === 'complete') pl.classList.add('loaded'); else window.addEventListener('load', () => pl.classList.add('loaded'), { once: true }); }

        const ro = new IntersectionObserver(es => { for (const e of es) { if (e.isIntersecting) { e.target.classList.add('in-view'); ro.unobserve(e.target); } } }, { rootMargin: '0px 0px -40px 0px', threshold: 0.05 });
        $$('.reveal-up, .line-draw').forEach(el => ro.observe(el));
        _clean.push(() => ro.disconnect());

        const btns = $$('.filter-btn');
        let aIdx = -1, cF = -1;

        const findActiveFromScroll = () => {
          const sy = scrollY, wh = innerHeight;
          let bestDist = Infinity, bestPI = -1;
          MMap.forEach((m, pi) => {
            const center = m.top + m.h / 2;
            const dist = Math.abs(center - (sy + wh / 2));
            if (dist < bestDist) { bestDist = dist; bestPI = pi; }
          });
          return bestPI;
        };

        const updateDotNav = () => {
          $$('.dot-nav-item').forEach(d => d.classList.toggle('active', +d.dataset.dot === aIdx));
        };

        const doFilter = (cat: string) => {
          btns.forEach(b => { const a = b.dataset.filter === cat; b.dataset.active = String(a); b.setAttribute('aria-selected', String(a)); });
          $$('.project-section').forEach(s => {
            const show = cat === 'All' || s.dataset.category === cat;
            (s as HTMLElement).style.display = show ? '' : 'none';
          });
          cacheM();
          aIdx = findActiveFromScroll();
          cF = -1;
          updateDotNav();
        };

        btns.forEach(b => { const h = () => doFilter(b.dataset.filter || 'All'); b.addEventListener('click', h); _clean.push(() => b.removeEventListener('click', h)); });

        interface MEntry { el: HTMLElement; top: number; h: number; cards: HTMLElement[]; dots: HTMLElement[]; }
        let MMap = new Map<number, MEntry>();

        const cacheM = () => {
          MMap.clear();
          $$('.project-section').forEach(s => {
            const el = s as HTMLElement;
            if (!el.offsetHeight) return;
            const pi = +el.dataset.projectIndex;
            MMap.set(pi, {
              el, top: el.offsetTop, h: el.offsetHeight,
              cards: [...el.querySelectorAll('.img-card')],
              dots: [...el.querySelectorAll('[data-dot-i]')]
            });
          });
        };
        cacheM();

        const po = new IntersectionObserver(es => {
          for (const e of es) {
            const el = e.target as HTMLElement;
            if (e.isIntersecting && el.offsetHeight > 0) {
              aIdx = +el.dataset.projectIndex || 0;
              cF = -1;
              updateDotNav();
            }
          }
        }, { rootMargin: '-40% 0px -40% 0px' });
        $$('.project-section').forEach(s => po.observe(s));
        _clean.push(() => po.disconnect());

        let rt = 0;
        const onR = () => { clearTimeout(rt); rt = setTimeout(cacheM, 200); };
        window.addEventListener('resize', onR, { passive: true });
        _clean.push(() => window.removeEventListener('resize', onR));

        const lerp = (a: number, b: number, t: number) => a + (b - a) * t;
        const pb = $('#scroll-progress'), hdr = $('#site-header'), btt = $('#back-to-top');
        const isMob = () => innerWidth < 768;

        const tick = () => {
          _raf = requestAnimationFrame(tick);
          const sy = scrollY, wh = innerHeight;

          if (pb) { const mx = document.documentElement.scrollHeight - wh; pb.style.width = mx > 0 ? `${(sy / mx) * 100}%` : '0%'; }
          if (hdr) hdr.classList.toggle('scrolled', sy > 40);
          if (btt) btt.classList.toggle('visible', sy > wh * 0.8);

          const d = aIdx >= 0 ? MMap.get(aIdx) : null;
          if (d) {
            const sc = Math.max(d.h - wh, 1);
            const p = Math.max(0, Math.min(1, (sy - d.top) / sc));
            const targetFocus = p * (d.cards.length - 1);

            if (cF < 0) cF = targetFocus;
            cF = lerp(cF, targetFocus, 0.16);

            const mob = isMob();
            let ad = 0;

            for (let i = 0; i < d.cards.length; i++) {
              const c = d.cards[i];
              const dist = i - cF;
              const adist = Math.abs(dist);

              if (adist > 1.8) {
                if (c.style.visibility !== 'hidden') {
                  c.style.visibility = 'hidden';
                  c.style.pointerEvents = 'none';
                  c.dataset.active = 'false';
                }
                continue;
              }

              if (c.style.visibility === 'hidden') c.style.visibility = 'visible';

              const xPct = dist * (mob ? 55 : 65);
              const rotY = dist * (mob ? -28 : -35);
              const zPush = -adist * (mob ? 60 : 100);
              const sc2 = Math.max(0.7, 1 - adist * 0.1);
              const op = Math.max(0, 1 - adist * 0.5);

              c.style.transform = `translate(-50%, -50%) perspective(1200px) translate3d(${xPct}%, 0, ${zPush}px) rotateY(${rotY}deg) scale(${sc2})`;
              c.style.opacity = String(op);
              c.style.zIndex = String(100 - Math.round(adist * 10));

              const act = adist < 0.45;
              c.dataset.active = String(act);
              c.style.pointerEvents = act ? 'auto' : 'none';
              if (act) ad = i;
            }

            for (let i = 0; i < d.dots.length; i++) {
              d.dots[i].className = `h-1 rounded-full transition-all ${i === ad ? 'bg-white/60 w-3' : 'bg-white/20 w-1'}`;
            }
          }
        };
        _raf = requestAnimationFrame(tick);

        // ═══════ LIGHTBOX ═══════
        let lbI: string[] = [], lbX = 0;
        const lb = $('#lightbox'), lbi = $('#lightbox-img') as HTMLImageElement, lbc = $('#lightbox-counter'), lbw = $('#img-zoom-wrapper') as HTMLElement;
        const lbOpt = (u: string) => { if (!u) return ''; try { const x = new URL(u, location.origin); if (x.hostname.includes('supabase.co') && x.pathname.includes('/object/')) { x.pathname = x.pathname.replace('/object/', '/render/image/'); x.searchParams.set('width', '1400'); x.searchParams.set('quality', '85'); return x.toString(); } } catch {} return u; };
        const lbUp = () => { if (lbi) { lbi.src = lbOpt(lbI[lbX]); lbi.alt = `Foto ${lbX + 1} dari ${lbI.length}`; } if (lbc) lbc.textContent = `${lbX + 1} / ${lbI.length}`; lbw.style.transform = 'scale(1)'; };
        const lbO = (imgs: string[], idx: number) => { lbI = imgs; lbX = idx; lbUp(); lb?.classList.remove('hidden'); document.body.style.overflow = 'hidden'; };
        const lbC = () => { lb?.classList.add('hidden'); document.body.style.overflow = ''; };
        const lbN = (dir: number) => { lbX = (lbX + dir + lbI.length) % lbI.length; lbUp(); };

        document.addEventListener('click', e => {
          const img = (e.target as Element).closest?.('.project-image') as HTMLImageElement | null;
          if (img) { try { lbO(JSON.parse(img.dataset.images || '[]'), +img.dataset.index); } catch {} return; }
          const btn = (e.target as Element).closest?.('[data-open-all-images]') as HTMLElement | null;
          if (btn) { try { lbO(JSON.parse(btn.dataset.openAllImages || '[]'), 0); } catch {} }
        });
        $('#close-lightbox')?.addEventListener('click', lbC);
        $('#prev-btn')?.addEventListener('click', () => lbN(-1));
        $('#next-btn')?.addEventListener('click', () => lbN(1));
        lb?.addEventListener('click', e => { if ((e.target as Element).classList.contains('lightbox-bg')) lbC(); });
        const onK = (e: KeyboardEvent) => { if (lb?.classList.contains('hidden')) return; if (e.key === 'Escape') lbC(); else if (e.key === 'ArrowLeft') lbN(-1); else if (e.key === 'ArrowRight') lbN(1); };
        document.addEventListener('keydown', onK);
        _clean.push(() => document.removeEventListener('keydown', onK));
        let tx = 0;
        lb?.addEventListener('touchstart', e => { tx = e.touches[0].clientX; }, { passive: true });
        lb?.addEventListener('touchend', e => { const dx = e.changedTouches[0].clientX - tx; if (Math.abs(dx) > 50) lbN(dx > 0 ? -1 : 1); }, { passive: true });

        btt?.addEventListener('click', () => scrollTo({ top: 0, behavior: 'smooth' }));

        // Music
        const mus = $('#bg-music') as HTMLAudioElement, mt = $('#music-toggle'), mp = $('#music-icon-play'), mpa = $('#music-icon-pause');
        let playing = false;
        mt?.addEventListener('click', () => {
          if (!mus) return;
          if (playing) {
            mus.pause(); mp?.classList.remove('hidden'); mpa?.classList.add('hidden'); mt.classList.remove('playing');
          } else {
            mus.play().catch(() => {}); mp?.classList.add('hidden'); mpa?.classList.remove('hidden'); mt.classList.add('playing');
          }
          playing = !playing;
        });

        // Form
        const wf = $('#wa-form') as HTMLFormElement, fe = $('#form-error');
        wf?.addEventListener('submit', e => {
          e.preventDefault();
          const n = ($('#wa-name') as HTMLInputElement)?.value?.trim(), t = ($('#wa-topic') as HTMLInputElement)?.value?.trim(), m = ($('#wa-message') as HTMLTextAreaElement)?.value?.trim();
          if (!n || !t || !m) { if (fe) { fe.textContent = 'Mohon lengkapi semua field.'; fe.classList.remove('hidden'); setTimeout(() => fe.classList.add('hidden'), 3000); } return; }
          open(`https://wa.me/6285707109853?text=${encodeURIComponent(`Halo! Saya ${n}.\nTopik: ${t}\nPesan: ${m}`)}`, '_blank', 'noopener');
        });
      }

      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init, { once: true }); else init();
      document.addEventListener('astro:page-load', init);
      document.addEventListener('astro:before-swap', () => { cancelAnimationFrame(_raf); _clean.forEach(f => f()); _clean = []; });
    </script>
  </body>
</html>
