---
export const prerender = false;
import { Boxes } from '../components/ui/background-boxes';
import { PixelHero } from '../components/ui/pixel-perfect-hero';
import { SplineScene } from '../components/ui/spline-scene';
import '../styles/global.css';
import { createClient } from '@supabase/supabase-js';
import { ClientRouter } from 'astro:transitions';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
const supabase = createClient(supabaseUrl, supabaseKey);

const { data: projects } = await supabase
  .from('projects')
  .select('*')
  .order('created_at', { ascending: false });

const categories = ['All', ...new Set(projects?.map(p => p.category).filter(Boolean))];

const ogImage = projects && projects.length > 0 && projects[0].image_urls && projects[0].image_urls.length > 0 
  ? projects[0].image_urls[0] 
  : new URL('/og-image.png', Astro.url.origin).href;

// Helper: max 3 images shown in scrollytelling, full set in lightbox
const MAX_SCROLL_IMAGES = 3;
---

<html lang="id" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Fatih | Complete Portfolio</title>
    <meta name="description" content="Eksplorasi karya dan proses Fatih." />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://prod.spline.design" />

    <meta property="og:title" content="Fatih | Complete Portfolio" />
    <meta property="og:description" content="Eksplorasi karya dan proses." />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content="Fatih | Complete Portfolio" />
    <meta property="twitter:description" content="Eksplorasi karya dan proses." />
    <meta property="twitter:image" content={ogImage} />
    <ClientRouter />

    <style>
      /* ============================================================
         BASE
      ============================================================ */
      *, *::before, *::after { box-sizing: border-box; }
      html {
        scroll-behavior: smooth;
        text-size-adjust: 100%;
        -webkit-text-size-adjust: 100%;
      }
      body {
        overscroll-behavior: none;
        -webkit-overflow-scrolling: touch;
      }
      ::-webkit-scrollbar { width: 2px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }
      .no-scrollbar::-webkit-scrollbar { display: none; }
      .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

      a, button, [role="button"] {
        touch-action: manipulation;
        -webkit-tap-highlight-color: transparent;
      }

      /* ============================================================
         SCROLL PROGRESS
      ============================================================ */
      #scroll-progress {
        position: fixed;
        top: 0; left: 0;
        width: 0%;
        height: 2px;
        background: linear-gradient(90deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.85) 50%, rgba(255,255,255,0) 100%);
        z-index: 9999;
        will-change: width;
        pointer-events: none;
      }

      /* ============================================================
         MARQUEE
      ============================================================ */
      @keyframes marquee {
        from { transform: translateX(0); }
        to   { transform: translateX(-50%); }
      }
      .animate-marquee {
        display: flex;
        width: max-content;
        animation: marquee 35s linear infinite;
        will-change: transform;
      }
      @media (prefers-reduced-motion: reduce) {
        .animate-marquee { animation: none; }
      }

      /* ============================================================
         MARQUEE SECTION — glassmorphism, zero gap from hero
      ============================================================ */
      #marquee-section {
        /* No border-top: hero's border-b handles the divide */
        border-bottom: 1px solid rgba(255,255,255,0.06);
        background: rgba(9,9,11,0.55);
        backdrop-filter: blur(18px) saturate(140%);
        -webkit-backdrop-filter: blur(18px) saturate(140%);
        /* Subtle inner highlight on top edge */
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.06);
      }

      /* ============================================================
         TYPOGRAPHY
      ============================================================ */
      .text-outline {
        color: transparent;
        -webkit-text-stroke: 1px rgba(255, 255, 255, 0.12);
        paint-order: stroke fill;
      }

      /* ============================================================
         PROJECT SECTION
      ============================================================ */
      .project-section {
        height: calc(var(--display-count) * 100svh);
        contain: layout style;
      }

      /* ============================================================
         REVEAL ANIMATIONS — composited only
      ============================================================ */
      .reveal-up {
        opacity: 0;
        transform: translateY(32px);
        transition:
          opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1),
          transform 0.9s cubic-bezier(0.16, 1, 0.3, 1);
        will-change: transform, opacity;
      }
      .reveal-up.in-view { opacity: 1; transform: translateY(0); }

      .reveal-right {
        opacity: 0;
        transform: translateX(40px);
        transition:
          opacity 1s cubic-bezier(0.16, 1, 0.3, 1),
          transform 1s cubic-bezier(0.16, 1, 0.3, 1);
        will-change: transform, opacity;
      }
      .reveal-right.in-view { opacity: 1; transform: translateX(0); }

      .delay-50  { transition-delay: 50ms; }
      .delay-100 { transition-delay: 100ms; }
      .delay-150 { transition-delay: 150ms; }
      .delay-200 { transition-delay: 200ms; }
      .delay-300 { transition-delay: 300ms; }
      .delay-400 { transition-delay: 400ms; }

      /* ============================================================
         IMAGE
      ============================================================ */
      .img-premium {
        transition:
          transform 1.4s cubic-bezier(0.16, 1, 0.3, 1),
          filter 1.4s cubic-bezier(0.16, 1, 0.3, 1);
        will-change: transform, filter;
        backface-visibility: hidden;
      }
      @media (min-width: 768px) and (hover: hover) {
        .img-premium {
          filter: grayscale(100%) brightness(0.65) contrast(1.1);
          transform: scale(1);
        }
        .img-container:hover .img-premium {
          filter: grayscale(0%) brightness(1);
          transform: scale(1.04);
        }
      }
      @media (max-width: 767px), (hover: none) {
        .img-premium {
          filter: grayscale(0%) brightness(0.85);
          transform: scale(1);
        }
      }

      /* ============================================================
         PARALLAX WRAPPER
      ============================================================ */
      .parallax-img-wrapper {
        position: absolute;
        inset: -8%;
        width: 116%;
        height: 116%;
        will-change: transform;
      }
      .parallax-img-wrapper .img-premium {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      @media (max-width: 767px) {
        .parallax-img-wrapper {
          position: absolute;
          inset: 0;
          width: 100%;
          height: 100%;
        }
      }

      /* ============================================================
         LINE DRAW
      ============================================================ */
      .line-draw {
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
        will-change: transform;
      }
      .line-draw.in-view { transform: scaleX(1); }

      /* ============================================================
         DOT NAV
      ============================================================ */
      #dot-nav {
        position: fixed;
        right: 1.25rem;
        top: 50%;
        transform: translateY(-50%);
        display: flex;
        flex-direction: column;
        gap: 8px;
        z-index: 60;
        pointer-events: none;
      }
      @media (max-width: 767px) { #dot-nav { display: none; } }
      .dot-nav-item {
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background: rgba(255,255,255,0.18);
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        pointer-events: auto;
        cursor: pointer;
      }
      .dot-nav-item.active {
        background: rgba(255,255,255,0.9);
        height: 18px;
        border-radius: 2px;
      }

      /* ============================================================
         PROJECT COUNTER
      ============================================================ */
      .project-counter {
        font-variant-numeric: tabular-nums;
        font-feature-settings: "tnum";
      }

      /* ============================================================
         CROSSHAIR (desktop)
      ============================================================ */
      #crosshair-h, #crosshair-v {
        position: fixed;
        pointer-events: none;
        z-index: 10;
        opacity: 0;
        transition: opacity 0.5s;
        will-change: transform;
      }
      #crosshair-h {
        left: 0; right: 0;
        height: 1px;
        background: linear-gradient(to right, transparent, rgba(255,255,255,0.15), transparent);
      }
      #crosshair-v {
        top: 0; bottom: 0;
        width: 1px;
        background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.15), transparent);
      }
      #cursor-coords {
        position: fixed;
        pointer-events: none;
        z-index: 10;
        font-family: 'Courier New', monospace;
        font-size: 9px;
        color: rgba(255,255,255,0.3);
        opacity: 0;
        transition: opacity 0.3s;
        letter-spacing: 0.1em;
        will-change: transform;
      }

      /* ============================================================
         FILTER NAV — offset untuk fixed navbar (56px)
      ============================================================ */
      #filter-nav {
        /* Duduk persis di bawah fixed navbar, tidak tertutup sama sekali */
        top: 56px;
      }

      /* Garis indikator aktif di bawah nav — slide animasi */
      #filter-nav-track {
        position: relative;
      }
      #filter-nav-indicator {
        position: absolute;
        bottom: 0;
        height: 2px;
        background: rgba(255,255,255,0.9);
        border-radius: 1px;
        transition: left 0.35s cubic-bezier(0.16, 1, 0.3, 1),
                    width 0.35s cubic-bezier(0.16, 1, 0.3, 1),
                    opacity 0.25s;
        pointer-events: none;
        will-change: left, width;
      }

      .filter-btn {
        position: relative;
        overflow: hidden;
        isolation: isolate;
        transition: color 0.25s, background 0.25s, border-color 0.25s, transform 0.15s;
      }
      .filter-btn:active { transform: scale(0.95); }

      /* Subtle shimmer on hover */
      .filter-btn::before {
        content: '';
        position: absolute;
        inset: 0;
        background: rgba(255,255,255,0.05);
        opacity: 0;
        transition: opacity 0.25s;
        border-radius: inherit;
      }
      .filter-btn:hover::before { opacity: 1; }

      /* Active state tambahan: ring glow */
      .filter-btn[data-active="true"] {
        box-shadow: 0 0 12px rgba(255,255,255,0.15);
      }

      /* ============================================================
         SITE HEADER — new top navbar
      ============================================================ */
      #site-header {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 200;
        padding: 0 1.5rem;
        height: 56px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: rgba(9,9,11,0.72);
        backdrop-filter: blur(20px) saturate(150%);
        -webkit-backdrop-filter: blur(20px) saturate(150%);
        border-bottom: 1px solid rgba(255,255,255,0.05);
        transition: background 0.4s, border-color 0.4s;
      }
      #site-header.scrolled {
        background: rgba(9,9,11,0.92);
        border-bottom-color: rgba(255,255,255,0.08);
      }
      .header-logo {
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.85);
        text-decoration: none;
        transition: color 0.2s;
      }
      .header-logo:hover { color: white; }
      .header-logo span {
        color: rgba(255,255,255,0.3);
        font-weight: 400;
      }
      .header-links {
        display: flex;
        align-items: center;
        gap: 0.25rem;
      }
      .header-link {
        font-size: 0.65rem;
        font-weight: 600;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.4);
        text-decoration: none;
        padding: 0.4rem 0.75rem;
        border-radius: 999px;
        transition: color 0.2s, background 0.2s;
      }
      .header-link:hover {
        color: white;
        background: rgba(255,255,255,0.06);
      }
      .header-cta {
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: black;
        background: white;
        padding: 0.45rem 1rem;
        border-radius: 999px;
        text-decoration: none;
        transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
        margin-left: 0.5rem;
      }
      .header-cta:hover {
        background: #e5e5e5;
        box-shadow: 0 0 20px rgba(255,255,255,0.15);
      }
      .header-cta:active { transform: scale(0.96); }
      @media (max-width: 767px) {
        .header-links .header-link { display: none; }
      }

      /* ============================================================
         CONTACT FORM
      ============================================================ */
      .glass-input {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        padding: 1rem 1.25rem;
        font-size: 0.875rem;
        color: white;
        width: 100%;
        outline: none;
        transition: border-color 0.3s, background 0.3s, box-shadow 0.3s;
        -webkit-appearance: none;
      }
      .glass-input::placeholder { color: rgba(255,255,255,0.25); }
      .glass-input:focus {
        border-color: rgba(255,255,255,0.4);
        background: rgba(255,255,255,0.07);
        box-shadow: 0 0 0 3px rgba(255,255,255,0.05);
      }
      .btn-submit {
        position: relative;
        overflow: hidden;
        isolation: isolate;
        background: white;
        color: black;
        font-weight: 700;
        font-size: 0.875rem;
        padding: 1rem;
        border-radius: 12px;
        width: 100%;
        transition: background 0.3s, transform 0.2s, box-shadow 0.3s;
        cursor: pointer;
        border: none;
      }
      .btn-submit:hover {
        background: #e5e5e5;
        box-shadow: 0 0 32px rgba(255,255,255,0.25);
      }
      .btn-submit:active { transform: scale(0.98); }
      .btn-submit::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.4) 50%, transparent 100%);
        transform: translateX(-100%);
        transition: transform 0.6s;
      }
      .btn-submit:hover::before { transform: translateX(100%); }

      /* ============================================================
         LIGHTBOX
      ============================================================ */
      #lightbox { contain: layout style; }
      .lightbox-bg {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.96);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
      }

      /* ============================================================
         MUSIC TOGGLE
      ============================================================ */
      #music-toggle {
        touch-action: manipulation;
        -webkit-tap-highlight-color: transparent;
        cursor: pointer;
        transition: background 0.3s, color 0.3s, transform 0.2s, box-shadow 0.3s;
      }
      #music-toggle:active { transform: scale(0.9); }

      /* ============================================================
         BACK TO TOP BUTTON
      ============================================================ */
      #back-to-top {
        position: fixed;
        bottom: 5.5rem;
        right: 1.5rem;
        z-index: 100;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: rgba(24,24,27,0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.1);
        color: rgba(255,255,255,0.6);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        opacity: 0;
        transform: translateY(12px) scale(0.9);
        transition: opacity 0.35s cubic-bezier(0.16,1,0.3,1), transform 0.35s cubic-bezier(0.16,1,0.3,1), background 0.25s, color 0.25s, box-shadow 0.25s;
        pointer-events: none;
        touch-action: manipulation;
        -webkit-tap-highlight-color: transparent;
      }
      #back-to-top.visible {
        opacity: 1;
        transform: translateY(0) scale(1);
        pointer-events: auto;
      }
      #back-to-top:hover {
        background: white;
        color: black;
        box-shadow: 0 0 24px rgba(255,255,255,0.2);
      }
      #back-to-top:active { transform: scale(0.9); }
      @media (min-width: 768px) {
        #back-to-top {
          bottom: 6rem;
          right: 2.5rem;
          width: 48px;
          height: 48px;
        }
        #music-toggle {
          bottom: 2.5rem;
          right: 2.5rem;
        }
      }

      /* ============================================================
         FOOTER — redesigned
      ============================================================ */
      #site-footer {
        position: relative;
        z-index: 50;
        background: #09090b;
        border-top: 1px solid rgba(255,255,255,0.06);
        overflow: hidden;
      }
      .footer-inner {
        max-width: 80rem;
        margin: 0 auto;
        padding: 3rem 1.5rem 2rem;
        display: grid;
        grid-template-columns: 1fr;
        gap: 2.5rem;
      }
      @media (min-width: 768px) {
        .footer-inner {
          grid-template-columns: 1fr auto;
          gap: 3rem;
          align-items: end;
        }
      }
      .footer-brand-name {
        font-size: 2rem;
        font-weight: 900;
        letter-spacing: -0.02em;
        color: rgba(255,255,255,0.06);
        line-height: 1;
        text-transform: uppercase;
        pointer-events: none;
        user-select: none;
      }
      @media (min-width: 768px) {
        .footer-brand-name { font-size: 3.5rem; }
      }
      .footer-tagline {
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.2);
        margin-top: 0.5rem;
      }
      .footer-socials {
        display: flex;
        gap: 0.5rem;
        margin-top: 1.5rem;
      }
      .footer-social-link {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: 1px solid rgba(255,255,255,0.08);
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(255,255,255,0.35);
        text-decoration: none;
        transition: border-color 0.25s, color 0.25s, background 0.25s;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.05em;
      }
      .footer-social-link:hover {
        border-color: rgba(255,255,255,0.3);
        color: white;
        background: rgba(255,255,255,0.05);
      }
      .footer-right {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.75rem;
      }
      @media (min-width: 768px) {
        .footer-right { align-items: flex-end; }
      }
      .footer-copy {
        font-size: 0.65rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.18);
      }
      .footer-copy a {
        color: rgba(255,255,255,0.35);
        text-decoration: none;
        transition: color 0.2s;
      }
      .footer-copy a:hover { color: rgba(255,255,255,0.75); }
      .footer-status {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.65rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.25);
      }
      .footer-status-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: #4ade80;
        box-shadow: 0 0 6px #4ade80;
        animation: pulse-dot 2.5s ease-in-out infinite;
      }
      @keyframes pulse-dot {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.4; }
      }
      .footer-divider {
        height: 1px;
        background: rgba(255,255,255,0.04);
        margin: 0;
      }
      .footer-bottom {
        padding: 1rem 1.5rem;
        max-width: 80rem;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        align-items: flex-start;
      }
      @media (min-width: 768px) {
        .footer-bottom {
          flex-direction: row;
          justify-content: space-between;
          align-items: center;
        }
      }
      .footer-nav-links {
        display: flex;
        gap: 1.25rem;
      }
      .footer-nav-link {
        font-size: 0.65rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.2);
        text-decoration: none;
        transition: color 0.2s;
      }
      .footer-nav-link:hover { color: rgba(255,255,255,0.6); }

      /* ============================================================
         SAFE AREA
      ============================================================ */
      @supports (padding: env(safe-area-inset-bottom)) {
        #music-toggle {
          bottom: calc(1.5rem + env(safe-area-inset-bottom));
        }
        #back-to-top {
          bottom: calc(5rem + env(safe-area-inset-bottom));
        }
        nav#filter-nav {
          padding-left: max(1.5rem, env(safe-area-inset-left));
          padding-right: max(1.5rem, env(safe-area-inset-right));
        }
      }
    </style>
  </head>

  <body class="bg-zinc-950 text-white font-sans selection:bg-white selection:text-black overflow-x-hidden">

    <!-- SCROLL PROGRESS -->
    <div id="scroll-progress" aria-hidden="true"></div>

    <!-- ============================================================
         SITE HEADER (top navbar)
    ============================================================ -->
    <header id="site-header">
      <a href="#" class="header-logo">Fatih <span>/ Portfolio</span></a>
      <nav class="header-links">
        <a href="#projects-container" class="header-link">Karya</a>
        <a href="#wa-form" class="header-link">Kontak</a>
        <a href="https://www.instagram.com/aftharmuhammad_" target="_blank" rel="noopener" class="header-link hidden md:inline-flex items-center gap-1.5">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          Instagram
        </a>
        <a href="#wa-form" class="header-cta">Kolaborasi ↗</a>
      </nav>
    </header>

    <!-- DOT NAV (desktop sidebar) -->
    <nav id="dot-nav" aria-hidden="true">
      {projects && projects.map((_, i) => (
        <div class="dot-nav-item" data-dot={i} title={`Project ${i + 1}`}></div>
      ))}
    </nav>

    <!-- ============================================================
         BACKGROUND
    ============================================================ -->
    <div class="fixed inset-0 -z-50 bg-[#09090b] pointer-events-none" aria-hidden="true">
      <div class="hidden md:block absolute inset-0 opacity-[0.05]"
           style="background-image: linear-gradient(to right, #ffffff 1px, transparent 1px), linear-gradient(to bottom, #ffffff 1px, transparent 1px); background-size: 4rem 4rem; contain: strict;">
      </div>
