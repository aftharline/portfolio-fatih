    <script>
      window.addEventListener('load', () => {
        const preloader = document.getElementById('preloader');
        if (preloader) setTimeout(() => preloader.classList.add('loaded'), 1500);
      });

      document.addEventListener('astro:page-load', () => {
        const qs  = (s: string) => document.querySelector(s);
        const qsa = (s: string) => document.querySelectorAll(s);
        const isMobile = () => window.innerWidth < 768;
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        // Scroll to Projects
        const scrollToProjects = () => {
          const el = document.getElementById('projects-container');
          if (el) window.scrollTo({ top: el.offsetTop, behavior: 'smooth' });
        };
        document.getElementById('footer-cta-portfolio')?.addEventListener('click', scrollToProjects);

        // ── 1. CUSTOM CURSOR & MAGNETIC BUTTONS ──────────────────
        const cursorDot = qs('#cursor-dot') as HTMLElement;
        const cursorRing = qs('#cursor-ring') as HTMLElement;
        let mX = 0, mY = 0, rX = 0, rY = 0;

        if (!isMobile()) {
          window.addEventListener('mousemove', e => {
            mX = e.clientX; mY = e.clientY;
            cursorDot.style.transform = `translate3d(${mX}px, ${mY}px, 0)`;
          });
          qsa('.magnetic').forEach(btn => {
            btn.addEventListener('mousemove', e => {
              const rect = btn.getBoundingClientRect();
              const x = e.clientX - rect.left - rect.width / 2;
              const y = e.clientY - rect.top - rect.height / 2;
              btn.style.transform = `translate(${x * 0.3}px, ${y * 0.3}px)`;
            });
            btn.addEventListener('mouseleave', () => { btn.style.transform = 'translate(0, 0)'; });
          });
          qsa('a, button, .magnetic, .project-image').forEach(el => {
            el.addEventListener('mouseenter', () => cursorRing.classList.add('hovering'));
            el.addEventListener('mouseleave', () => cursorRing.classList.remove('hovering'));
          });
        }

        // ── 2. REVEAL OBSERVER ───────────────────────────────────
        const revealObs = new IntersectionObserver(
          entries => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in-view'); revealObs.unobserve(e.target); } }),
          { rootMargin: '0px 0px -60px 0px', threshold: 0.1 }
        );
        qsa('.reveal-up, .reveal-right, .line-draw').forEach(el => revealObs.observe(el));

        // ── 3. FILTER (Moved to Dock) ────────────────────────────
        const filterBtns = qsa('.filter-btn') as NodeListOf<HTMLElement>;
        const setActiveFilter = (targetBtn: HTMLElement) => {
          filterBtns.forEach(b => b.setAttribute('data-active', 'false'));
          targetBtn.setAttribute('data-active', 'true');
          targetBtn.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
          const filter = targetBtn.getAttribute('data-filter');
          (qsa('.project-section') as NodeListOf<HTMLElement>).forEach(s => {
            s.style.display = (filter === 'All' || s.getAttribute('data-category') === filter) ? 'block' : 'none';
          });
          cacheMetrics();
        };
        filterBtns.forEach(btn => btn.addEventListener('click', () => setActiveFilter(btn)));

        // ── 4. GLOBAL ANIMATION ENGINE ──────────────────────────
        let metrics: { el: HTMLElement; top: number; height: number; cards: HTMLElement[]; dots: HTMLElement[] }[] = [];
        let activeProjectIndex = -1;
        let currentFocus = -1;
        
        const tunnelSection = qs('#philosophy-section') as HTMLElement;
        const tunnelTrack = qs('#tunnel-track') as HTMLElement;
        const tunnelQuote = qs('#tunnel-quote') as HTMLElement;
        const progressBar = qs('#scroll-progress') as HTMLElement;

        const cacheMetrics = () => {
          metrics = [];
          qsa('.project-section').forEach(sec => {
            if (sec.style.display !== 'none') {
              metrics.push({
                el: sec as HTMLElement,
                top: sec.offsetTop,
                height: sec.offsetHeight,
                cards: Array.from(sec.querySelectorAll('.img-3d-card')) as HTMLElement[],
                dots: Array.from(sec.querySelectorAll('[data-dot-i]')) as HTMLElement[]
              });
            }
          });
        };
        cacheMetrics();

        const projObs = new IntersectionObserver((entries) => {
          entries.forEach(e => {
            if (e.isIntersecting) {
              const idx = parseInt((e.target as HTMLElement).dataset.projectIndex || '0');
              activeProjectIndex = idx;
              currentFocus = -1;
            }
          });
        }, { rootMargin: '-45% 0px -45% 0px' });
        qsa('.project-section').forEach(s => projObs.observe(s));

        let resizeTimer;
        window.addEventListener('resize', () => { clearTimeout(resizeTimer); resizeTimer = setTimeout(cacheMetrics, 250); });

        const lerp = (a: number, b: number, t: number) => a + (b - a) * t;

        const animate = () => {
          const scrollY = window.scrollY;
          const winH = window.innerHeight;

          const max = document.documentElement.scrollHeight - winH;
          progressBar.style.width = max > 0 ? `${(scrollY / max) * 100}%` : '0%';

          if (!isMobile()) {
            rX = lerp(rX, mX, 0.2); rY = lerp(rY, mY, 0.2);
            cursorRing.style.transform = `translate3d(${rX}px, ${rY}px, 0)`;
          }

          if (activeProjectIndex >= 0 && metrics[activeProjectIndex]) {
            const d = metrics[activeProjectIndex];
            const scrollable = Math.max(d.height - winH, 1);
            const progress = Math.max(0, Math.min(1, (scrollY - d.top) / scrollable));
            const targetFocus = progress * (d.cards.length - 1);
            
            currentFocus = lerp(currentFocus, targetFocus, 0.12);
            const isMobileView = isMobile();
            let activeDotIndex = 0;

            d.cards.forEach((card, i) => {
              const dist = i - currentFocus;
              const absDist = Math.abs(dist);

              if (absDist > 1.5) {
                if (card.style.opacity !== '0') {
                  card.style.opacity = '0'; card.style.pointerEvents = 'none';
                  card.dataset.active = "false";
                }
                return;
              }

              const xMove = dist * (isMobileView ? 55 : 65);
              const zMove = -absDist * (isMobileView ? 200 : 300);
              const rotY = dist * (isMobileView ? -35 : -40);
              const opacity = 1 - absDist * 0.5;
              const scale = 1 - absDist * 0.1;

              card.style.transform = `translate(-50%, -50%) translate3d(${xMove}%, 0, ${zMove}px) rotateY(${rotY}deg) scale(${scale})`;
              card.style.opacity = opacity.toString();
              card.style.zIndex = (100 - Math.round(absDist * 10)).toString();
              
              const isActive = absDist < 0.5;
              card.dataset.active = isActive ? "true" : "false";
              
              if (isActive) { card.style.pointerEvents = "auto"; activeDotIndex = i; }
              else { card.style.pointerEvents = "none"; }
            });

            d.dots.forEach((dot, i) => {
              if (i === activeDotIndex) { dot.classList.remove('bg-white/20', 'w-1'); dot.classList.add('bg-white/60', 'w-3'); }
              else { dot.classList.remove('bg-white/60', 'w-3'); dot.classList.add('bg-white/20', 'w-1'); }
            });
          }

          if (tunnelSection && tunnelTrack) {
            const tTop = tunnelSection.offsetTop;
            const tHeight = tunnelSection.offsetHeight;
            if (scrollY >= tTop - winH && scrollY < tTop + tHeight) {
              const scrollable = tHeight - winH;
              const progress = Math.max(0, Math.min(1, (scrollY - tTop) / scrollable));
              const z = 500 - (progress * 3800);
              tunnelTrack.style.transform = `translate3d(0, 0, ${z}px)`;
              if (progress > 0.3 && progress < 0.7) tunnelQuote.classList.add('visible');
              else tunnelQuote.classList.remove('visible');
            }
          }

          requestAnimationFrame(animate);
        };

        if (!prefersReducedMotion) requestAnimationFrame(animate);

        // ── 5. MUSIC & BACK TO TOP ───────────────────────────────
        const bgMusic = qs('#bg-music') as HTMLAudioElement;
        const musicToggle = qs('#music-toggle') as HTMLButtonElement;
        if (musicToggle && bgMusic) {
          bgMusic.volume = 0.25; let playing = false;
          musicToggle.addEventListener('click', () => {
            if (playing) {
              bgMusic.pause(); qs('#music-icon-pause')?.classList.add('hidden'); qs('#music-icon-play')?.classList.remove('hidden'); musicToggle.classList.remove('playing');
            } else {
              bgMusic.play().catch(() => {}); qs('#music-icon-play')?.classList.add('hidden'); qs('#music-icon-pause')?.classList.remove('hidden'); musicToggle.classList.add('playing');
            } playing = !playing;
          });
        }

        const btt = qs('#back-to-top') as HTMLButtonElement;
        if (btt) {
          const toggleBtt = () => btt.classList.toggle('visible', window.scrollY > 400);
          window.addEventListener('scroll', toggleBtt, { passive: true });
          btt.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
        }

        // ── 6. LIGHTBOX ──────────────────────────────────────────
        const lightbox = qs('#lightbox') as HTMLElement;
        if (lightbox) {
          const lbImg = qs('#lightbox-img') as HTMLImageElement;
          const zoomWrap = qs('#img-zoom-wrapper') as HTMLElement;
          const counter = qs('#lightbox-counter') as HTMLElement;
          const closeBtn = qs('#close-lightbox') as HTMLButtonElement;
          const prevBtn = qs('#prev-btn') as HTMLButtonElement;
          const nextBtn = qs('#next-btn') as HTMLButtonElement;
          const btnZIn = qs('#zoom-in') as HTMLButtonElement;
          const btnZOut = qs('#zoom-out') as HTMLButtonElement;
          const btnZRst = qs('#zoom-reset') as HTMLButtonElement;
          const zoomInd = qs('#zoom-indicator') as HTMLElement;
          let imgs: string[] = []; let idx = 0; let zoom = 1;
          let closeTimeout: any;

          const applyZoom = () => { zoomWrap.style.transform = `scale(${zoom})`; zoomInd.textContent = `${Math.round(zoom * 100)}%`; };
          const resetZoom = () => { zoom = 1; applyZoom(); };
          const setImg = () => { lbImg.src = imgs[idx]; counter.textContent = `${idx + 1} / ${imgs.length}`; resetZoom(); const single = imgs.length <= 1; prevBtn.classList.toggle('hidden', single); nextBtn.classList.toggle('hidden', single); };
          
          const open = (images: string[], startIdx: number) => {
            clearTimeout(closeTimeout);
            imgs = images; idx = startIdx;
            lightbox.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
            setImg();
            requestAnimationFrame(() => {
              zoomWrap.style.transform = 'scale(1)';
              lightbox.style.opacity = '1';
            });
          };
          
          const close = () => {
            lightbox.style.opacity = '0';
            zoomWrap.style.transform = 'scale(0.95)';
            closeTimeout = setTimeout(() => {
              lightbox.classList.add('hidden');
              document.body.style.overflow = '';
              resetZoom();
            }, 300);
          };

          document.getElementById('projects-container')?.addEventListener('click', e => {
            const target = (e.target as HTMLElement).closest('.project-image') as HTMLImageElement | null;
            if (target) {
              e.stopPropagation();
              open(JSON.parse(target.dataset.images!), 0);
              return;
            }
            const btn = (e.target as HTMLElement).closest('[data-open-all-images]') as HTMLElement | null;
            if (btn) {
              e.stopPropagation();
              open(JSON.parse(btn.dataset.openAllImages!), 0);
            }
          });

          nextBtn.addEventListener('click', e => { e.stopPropagation(); idx = (idx + 1) % imgs.length; setImg(); });
          prevBtn.addEventListener('click', e => { e.stopPropagation(); idx = (idx - 1 + imgs.length) % imgs.length; setImg(); });
          closeBtn.addEventListener('click', close);
          lightbox.addEventListener('click', e => { if (e.target === lightbox || (e.target as HTMLElement).classList.contains('lightbox-bg')) close(); });
          btnZIn.addEventListener('click', e => { e.stopPropagation(); zoom = Math.min(zoom + 0.25, 3.5); applyZoom(); });
          btnZOut.addEventListener('click', e => { e.stopPropagation(); zoom = Math.max(zoom - 0.25, 0.5); applyZoom(); });
          btnZRst.addEventListener('click', e => { e.stopPropagation(); resetZoom(); });

          let txStart = 0;
          lightbox.addEventListener('touchstart', e => { txStart = e.touches[0].clientX; }, { passive: true });
          lightbox.addEventListener('touchend', e => { const dx = e.changedTouches[0].clientX - txStart; if (Math.abs(dx) > 60 && imgs.length > 1) dx < 0 ? nextBtn.click() : prevBtn.click(); }, { passive: true });

          document.addEventListener('keydown', e => {
            if (lightbox.classList.contains('hidden')) return;
            if (e.key === 'Escape') close(); if (e.key === 'ArrowRight') nextBtn.click(); if (e.key === 'ArrowLeft') prevBtn.click();
            if (e.key === '=' || e.key === '+') btnZIn.click(); if (e.key === '-') btnZOut.click();
          });
        }

        // ── 7. WA FORM ───────────────────────────────────────────
        const waForm = qs('#wa-form') as HTMLFormElement;
        if (waForm) {
          waForm.addEventListener('submit', e => {
            e.preventDefault();
            const name = (qs('#wa-name') as HTMLInputElement).value.trim();
            const topic = (qs('#wa-topic') as HTMLInputElement).value.trim();
            const message = (qs('#wa-message') as HTMLTextAreaElement).value.trim();
            if (!name || !topic || !message) return;
            const text = `Halo Fatih, saya ${name}.\n\nSaya mau ngobrolin soal: *${topic}*\n\n${message}`;
            window.open(`https://wa.me/6285707109853?text=${encodeURIComponent(text)}`, '_blank', 'noopener');
          });
        }

        // ── 8. CROSSHAIR ─────────────────────────────────────────
        if (isMobile() || prefersReducedMotion) return;
        const chH = qs('#crosshair-h') as HTMLElement;
        const chV = qs('#crosshair-v') as HTMLElement;
        const coords = qs('#cursor-coords') as HTMLElement;
        let chVisible = false;

        window.addEventListener('mousemove', e => {
          if (!chVisible) { chH.style.opacity='1'; chV.style.opacity='1'; coords.style.opacity='1'; chVisible = true; }
          chH.style.transform = `translate3d(0, ${e.clientY}px, 0)`;
          chV.style.transform = `translate3d(${e.clientX}px, 0, 0)`;
          coords.style.transform = `translate3d(${e.clientX + 14}px, ${e.clientY + 14}px, 0)`;
          coords.textContent = `X:${Math.round(e.clientX)} // Y:${Math.round(e.clientY)}`;
        });
        document.addEventListener('mouseleave', () => { chH.style.opacity='0'; chV.style.opacity='0'; coords.style.opacity='0'; chVisible = false; });
      });
    </script>
  </body>
</html>
