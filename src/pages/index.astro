---
export const prerender = false;
import { PixelHero } from '../components/ui/pixel-perfect-hero';
import '../styles/global.css';
import { createClient } from '@supabase/supabase-js';
import { ClientRouter } from 'astro:transitions';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
const supabase = createClient(supabaseUrl, supabaseKey);

const { data: projects } = await supabase
  .from('projects')
  .select('*')
  .order('created_at', { ascending: false });

const categories = ['All', ...new Set(projects?.map(p => p.category).filter(Boolean))];
const ogImage = projects?.[0]?.image_urls?.[0] || new URL('/og-image.png', Astro.url.origin).href;
const MAX_SCROLL_IMAGES = 3;

function optImg(url: string, w = 800, q = 75): string {
  if (!url) return '';
  try {
    const u = new URL(url, Astro.url.origin);
    if (u.hostname.includes('supabase.co') && u.pathname.includes('/storage/v1/object/')) {
      u.pathname = u.pathname.replace('/object/', '/render/image/');
      u.searchParams.set('width', String(w));
      u.searchParams.set('quality', String(q));
      return u.toString();
    }
  } catch {}
  return url;
}

const jsonLd = {
  '@context': 'https://schema.org', '@type': 'Person',
  name: 'Muhammad Abdee Nur Fatih', url: Astro.url.href,
  jobTitle: 'Informatics Student & Designer',
  description: 'Eksplorasi desain visual, kepemimpinan, dan teknologi informasi.',
  sameAs: ['https://www.instagram.com/aftharmuhammad_'], image: ogImage,
};
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Fatih | Complete Portfolio</title>
    <meta name="description" content="Eksplorasi karya dan proses Muhammad Fatih — desain visual, kepemimpinan, teknologi informasi." />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="preconnect" href={supabaseUrl} crossorigin />
    <link rel="dns-prefetch" href="https://prod.spline.design" />
    <meta property="og:title" content="Fatih | Portfolio" />
    <meta property="og:description" content="Eksplorasi karya dan proses." />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <ClientRouter />

    <style>
      *, *::before, *::after { box-sizing: border-box; }
      body, .font-sans { font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif !important; }
      html { text-size-adjust: 100%; }
      body { overscroll-behavior: none; overflow-x: clip; background: #09090b; color: #fff; }
      ::-webkit-scrollbar { width: 2px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }
      .no-scrollbar::-webkit-scrollbar { display: none; }
      .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
      a, button { touch-action: manipulation; -webkit-tap-highlight-color: transparent; }
      :focus-visible { outline: 2px solid rgba(255,255,255,0.6); outline-offset: 2px; }
      :focus:not(:focus-visible) { outline: none; }

      /* PRELOADER */
      #preloader { position: fixed; inset: 0; z-index: 10000; background: #09090b; display: flex; align-items: center; justify-content: center; transition: opacity 0.4s ease; contain: strict; }
      #preloader.loaded { opacity: 0; pointer-events: none; }
      .pl-text { font-size: 1.5rem; font-weight: 900; letter-spacing: 0.2em; color: #fff; margin-bottom: 1.5rem; opacity: 0; animation: plFade 0.5s ease 0.1s forwards; }
      @keyframes plFade { to { opacity: 1; } }
      .pl-bar { width: 100%; height: 1px; background: rgba(255,255,255,0.1); overflow: hidden; }
      .pl-progress { width: 0%; height: 100%; background: #fff; animation: plLoad 1s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
      @keyframes plLoad { to { width: 100%; } }

      #scroll-progress { position: fixed; top: 0; left: 0; width: 0%; height: 2px; background: #fff; z-index: 9999; pointer-events: none; contain: strict; }

      /* MARQUEE */
      @keyframes marquee { to { transform: translateX(-50%); } }
      .animate-marquee { display: flex; width: max-content; animation: marquee 35s linear infinite; contain: layout style; }
      @media (prefers-reduced-motion: reduce) { .animate-marquee { animation: none; } }
      .text-outline { color: transparent; -webkit-text-stroke: 1px rgba(255,255,255,0.12); paint-order: stroke fill; }

      /* REVEAL */
      .reveal-up { opacity: 0; transform: translateY(24px); transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1); }
      .reveal-up.in-view { opacity: 1; transform: translateY(0); }
      .delay-50 { transition-delay: 50ms; } .delay-100 { transition-delay: 100ms; }
      .delay-150 { transition-delay: 150ms; } .delay-200 { transition-delay: 200ms; }
      .delay-300 { transition-delay: 300ms; } .delay-400 { transition-delay: 400ms; }
      .line-draw { transform: scaleX(0); transform-origin: left; transition: transform 1s cubic-bezier(0.16, 1, 0.3, 1); }
      .line-draw.in-view { transform: scaleX(1); }

      /* ═══════════════════════════════════════════════════════
         HEADER + FILTER
      ═══════════════════════════════════════════════════════ */
      #site-header { position: fixed; top: 0; left: 0; right: 0; z-index: 200; background: rgba(9,9,11,0.95); border-bottom: 1px solid rgba(255,255,255,0.05); transition: background 0.3s, border-color 0.3s; }
      #site-header.scrolled { background: rgba(9,9,11,0.98); border-bottom-color: rgba(255,255,255,0.08); }
      .header-inner { max-width: 100%; display: flex; align-items: center; padding: 0 1.25rem; height: 56px; gap: 0.75rem; }
      .header-logo { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.85); text-decoration: none; white-space: nowrap; flex-shrink: 0; transition: color 0.2s; }
      .header-logo:hover { color: white; }
      .header-logo span { color: rgba(255,255,255,0.3); font-weight: 400; }
      .header-filters { flex: 1; display: flex; align-items: center; justify-content: center; gap: 0.4rem; overflow-x: auto; padding: 0 0.5rem; scrollbar-width: none; }
      .header-filters::-webkit-scrollbar { display: none; }
      .filter-btn { flex-shrink: 0; display: flex; align-items: center; gap: 0.4rem; padding: 0.3rem 0.7rem; border-radius: 999px; font-size: 10px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; border: 1px solid rgba(255,255,255,0.08); color: rgba(255,255,255,0.4); background: transparent; cursor: pointer; white-space: nowrap; transition: color 0.2s, background 0.2s, border-color 0.2s, transform 0.1s; }
      .filter-btn:hover { color: white; border-color: rgba(255,255,255,0.2); }
      .filter-btn:active { transform: scale(0.95); }
      .filter-btn[data-active="true"] { background: #fff; color: #000; border-color: #fff; }
      .filter-btn .f-count { font-family: 'Courier New', monospace; font-size: 9px; opacity: 0.5; font-variant-numeric: tabular-nums; }
      .header-actions { display: flex; align-items: center; gap: 0.25rem; flex-shrink: 0; }
      .header-link { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(255,255,255,0.4); text-decoration: none; padding: 0.4rem 0.75rem; border-radius: 999px; transition: color 0.2s, background 0.2s; }
      .header-link:hover { color: white; background: rgba(255,255,255,0.06); }
      .header-cta { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: black; background: white; padding: 0.45rem 1rem; border-radius: 999px; text-decoration: none; transition: background 0.2s; margin-left: 0.25rem; white-space: nowrap; }
      .header-cta:hover { background: #e5e5e5; }
      @media (max-width: 767px) {
        .header-inner { padding: 0 1rem; gap: 0.5rem; }
        .header-logo span { display: none; }
        .header-actions .header-link { display: none; }
        .header-filters { justify-content: flex-start; gap: 0.3rem; padding: 0; }
        .filter-btn { padding: 0.25rem 0.55rem; font-size: 9px; letter-spacing: 0.08em; }
        .filter-btn .f-count { display: none; }
      }
      @media (min-width: 768px) and (max-width: 1023px) { .header-actions .header-link:not(:last-child) { display: none; } }

      /* ═══════════════════════════════════════════════════════
         SMOOTH 3D CAROUSEL
      ═══════════════════════════════════════════════════════ */
      .project-section { position: relative; height: calc(var(--display-count) * 100svh); z-index: 1; contain: layout style; }
      .project-sticky-view { position: sticky; top: 0; height: 100svh; width: 100%; overflow: hidden; display: flex; align-items: center; justify-content: center; }
      .project-bg-glow { position: absolute; width: 60%; height: 50%; background: radial-gradient(circle, rgba(255,255,255,0.02) 0%, transparent 70%); filter: blur(60px); z-index: 0; pointer-events: none; }
      .image-card-container { position: absolute; inset: 0; z-index: 10; pointer-events: none; }

      .img-card {
        position: absolute; top: 50%; left: 50%; width: 85%; max-width: 550px; height: 65%; border-radius: 16px; overflow: hidden;
        pointer-events: none; backface-visibility: hidden; background: #18181b;
        transform: translate(-50%, -50%) perspective(1200px) translateX(80%) rotateY(40deg) scale(0.85);
        opacity: 0;
        box-shadow: 0 30px 60px -15px rgba(0,0,0,0.7), 0 0 0 1px rgba(255,255,255,0.05);
      }
      .img-card[data-active="true"] { box-shadow: 0 0 60px 5px rgba(255,255,255,0.06), 0 30px 60px -15px rgba(0,0,0,0.8); }
      .img-card img { width: 100%; height: 100%; object-fit: cover; pointer-events: none; }
      .img-card-dim { position: absolute; inset: 0; background: rgba(9,9,11,0.75); z-index: 2; opacity: 1; pointer-events: none; transition: opacity 0.3s; }
      .img-card[data-active="true"] .img-card-dim { opacity: 0; }
      .img-card-gloss { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, transparent 40%, transparent 60%, rgba(0,0,0,0.2) 100%); pointer-events: none; z-index: 3; }

      .text-panel { position: absolute; bottom: 0; left: 0; width: 100%; height: 100%; z-index: 20; pointer-events: none; background: linear-gradient(to top, rgba(9,9,11,1) 10%, transparent 100%); display: flex; flex-direction: column; justify-content: flex-end; padding: 1.5rem 1.5rem 5rem; }
      @media (min-width: 768px) {
        .img-card { left: 65%; max-width: 600px; height: 70%; }
        .text-panel { top: 0; bottom: auto; left: 0; width: 50%; height: 100%; padding: 6rem 4rem; background: linear-gradient(to right, rgba(9,9,11,1) 30%, transparent 100%); justify-content: center; }
      }

      /* DOT NAV */
      #dot-nav { position: fixed; right: 1.25rem; top: 50%; transform: translateY(-50%); display: flex; flex-direction: column; gap: 8px; z-index: 60; pointer-events: none; }
      @media (max-width: 767px) { #dot-nav { display: none; } }
      .dot-nav-item { width: 4px; height: 4px; border-radius: 50%; background: rgba(255,255,255,0.18); transition: all 0.3s; pointer-events: auto; }
      .dot-nav-item.active { background: rgba(255,255,255,0.9); height: 18px; border-radius: 2px; }
      .project-counter { font-variant-numeric: tabular-nums; }

      /* ═══════════════════════════════════════════════════════
         SILVER HOLOGRAM — Responsive
      ═══════════════════════════════════════════════════════ */
      .hologram-wrap {
        position: relative;
        /* Mobile: 200x240, Tablet: 340x400, Desktop: 440x500 */
        width: 220px; height: 260px;
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
      }
      @media (min-width: 640px) { .hologram-wrap { width: 340px; height: 400px; } }
      @media (min-width: 1024px) { .hologram-wrap { width: 440px; height: 500px; } }

      .hologram-wrap::before {
        content: ''; position: absolute; inset: -30px;
        background: radial-gradient(ellipse at 50% 45%, rgba(200,205,215,0.08) 0%, transparent 65%);
        animation: holo-breathe 4s ease-in-out infinite;
      }
      .holo-hex {
        position: absolute; width: 88px; height: 88px;
        clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
        background: linear-gradient(180deg, rgba(200,205,215,0.14), rgba(200,205,215,0.04));
        animation: holo-float 6s ease-in-out infinite;
      }
      @media (min-width: 640px) { .holo-hex { width: 110px; height: 110px; } }
      @media (min-width: 1024px) { .holo-hex { width: 120px; height: 120px; } }

      .holo-hex-ring {
        position: absolute; width: 96px; height: 96px;
        clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
        background: conic-gradient(from 0deg, rgba(200,205,215,0.5), transparent 25%, rgba(200,205,215,0.5) 50%, transparent 75%, rgba(200,205,215,0.5));
        animation: holo-spin 8s linear infinite;
      }
      @media (min-width: 640px) { .holo-hex-ring { width: 120px; height: 120px; } }
      @media (min-width: 1024px) { .holo-hex-ring { width: 132px; height: 132px; } }

      .holo-hex-inner {
        position: absolute; width: 50px; height: 50px;
        clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
        background: rgba(200,205,215,0.06);
        animation: holo-spin 12s linear infinite reverse;
      }
      @media (min-width: 640px) { .holo-hex-inner { width: 65px; height: 65px; } }
      @media (min-width: 1024px) { .holo-hex-inner { width: 72px; height: 72px; } }

      .holo-orbit { position: absolute; border-radius: 50%; border: 1px solid transparent; }
      .holo-orbit-1 { width: 55%; aspect-ratio: 1; border-top-color: rgba(200,205,215,0.5); border-right-color: rgba(200,205,215,0.08); animation: holo-spin 7s linear infinite; }
      .holo-orbit-2 { width: 75%; aspect-ratio: 1; border-bottom-color: rgba(200,205,215,0.3); border-left-color: rgba(200,205,215,0.06); border-style: dashed; animation: holo-spin 13s linear infinite reverse; }
      .holo-orbit-3 { width: 95%; aspect-ratio: 1; border-top-color: rgba(200,205,215,0.12); border-left-color: rgba(200,205,215,0.04); animation: holo-spin 20s linear infinite; }
      .holo-orbit-4 { width: 65%; aspect-ratio: 0.63; border-top-color: rgba(200,205,215,0.2); border-bottom-color: rgba(200,205,215,0.05); animation: holo-spin 10s linear infinite reverse; transform: rotateX(65deg); }
      /* Sembunyikan orbit 3 & 4 di mobile untuk performa */
      .holo-orbit-3, .holo-orbit-4 { display: none; }
      @media (min-width: 640px) { .holo-orbit-3, .holo-orbit-4 { display: block; } }

      .holo-scan {
        position: absolute; width: 80%; height: 1.5px;
        background: linear-gradient(90deg, transparent 0%, rgba(200,205,215,0.06) 20%, rgba(220,225,235,0.7) 50%, rgba(200,205,215,0.06) 80%, transparent 100%);
        animation: holo-sweep 3.5s ease-in-out infinite;
        box-shadow: 0 0 12px rgba(200,205,215,0.35);
      }
      .holo-lines {
        position: absolute; inset: 15px; border-radius: 50%; pointer-events: none;
        background: repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(200,205,215,0.015) 3px, rgba(200,205,215,0.015) 4px);
        /* Sembunyikan scanlines di mobile */
        display: none;
      }
      @media (min-width: 640px) { .holo-lines { display: block; } }

      .holo-floor {
        position: absolute; bottom: 5px; left: 50%;
        transform: translateX(-50%) perspective(200px) rotateX(65deg);
        width: 80%; aspect-ratio: 2.36;
        background:
          linear-gradient(rgba(200,205,215,0.07) 1px, transparent 1px),
          linear-gradient(90deg, rgba(200,205,215,0.07) 1px, transparent 1px);
        background-size: 22px 22px;
        -webkit-mask-image: linear-gradient(to top, rgba(0,0,0,0.5), transparent);
        mask-image: linear-gradient(to top, rgba(0,0,0,0.5), transparent);
        animation: holo-floor-pulse 4s ease-in-out infinite;
      }
      .holo-particle {
        position: absolute; width: 2.5px; height: 2.5px;
        background: rgba(220,225,235,0.9); border-radius: 50%;
        box-shadow: 0 0 6px rgba(200,205,215,0.7), 0 0 14px rgba(200,205,215,0.25);
      }
      /* Hanya 4 partikel di mobile, 8 di desktop */
      .holo-particle.p-desktop { display: none; }
      @media (min-width: 640px) { .holo-particle.p-desktop { display: block; } }

      .holo-bracket { position: absolute; width: 20px; height: 20px; border-color: rgba(200,205,215,0.25); border-style: solid; border-width: 0; }
      .holo-bracket.tl { top: 10%; left: 5%; border-top-width: 1px; border-left-width: 1px; }
      .holo-bracket.tr { top: 10%; right: 5%; border-top-width: 1px; border-right-width: 1px; }
      .holo-bracket.bl { bottom: 15%; left: 5%; border-bottom-width: 1px; border-left-width: 1px; }
      .holo-bracket.br { bottom: 15%; right: 5%; border-bottom-width: 1px; border-right-width: 1px; }
      /* Sembunyikan bracket di mobile */
      .holo-bracket { display: none; }
      @media (min-width: 640px) { .holo-bracket { display: block; } }

      .holo-data { position: absolute; font-family: 'Courier New', monospace; font-size: 8px; letter-spacing: 0.15em; color: rgba(200,205,215,0.2); white-space: nowrap; pointer-events: none; display: none; }
      @media (min-width: 640px) { .holo-data { display: block; } }
      .holo-vline { position: absolute; width: 1px; background: linear-gradient(to bottom, transparent, rgba(200,205,215,0.15), transparent); display: none; }
      @media (min-width: 640px) { .holo-vline { display: block; } }

      @keyframes holo-breathe { 0%, 100% { opacity: 0.6; transform: scale(1); } 50% { opacity: 1; transform: scale(1.04); } }
      @keyframes holo-float { 0%, 100% { transform: translateY(0) rotate(0deg); } 50% { transform: translateY(-12px) rotate(2deg); } }
      @keyframes holo-spin { to { transform: rotate(360deg); } }
      @keyframes holo-sweep { 0% { transform: translateY(-130px); opacity: 0; } 15% { opacity: 1; } 85% { opacity: 1; } 100% { transform: translateY(130px); opacity: 0; } }
      @keyframes holo-floor-pulse { 0%, 100% { opacity: 0.6; } 50% { opacity: 1; } }

      /* FORM */
      .glass-input { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 1rem 1.25rem; font-size: 0.875rem; color: white; width: 100%; outline: none; transition: border-color 0.2s, background 0.2s; -webkit-appearance: none; }
      .glass-input::placeholder { color: rgba(255,255,255,0.25); }
      .glass-input:focus { border-color: rgba(255,255,255,0.4); background: rgba(255,255,255,0.07); }
      .btn-submit { background: white; color: black; font-weight: 700; font-size: 0.875rem; padding: 1rem; border-radius: 12px; width: 100%; cursor: pointer; border: none; transition: background 0.2s; }
      .btn-submit:hover { background: #e5e5e5; }

      /* LIGHTBOX */
      #lightbox { contain: layout style; }
      #lightbox.hidden { display: none; }
      #img-zoom-wrapper { transition: transform 0.3s ease-out; }
      .lightbox-bg { position: absolute; inset: 0; background: rgba(0,0,0,0.96); }

      /* ═══════════════════════════════════════════════════════
         FAB BUTTONS — Premium Style
      ═══════════════════════════════════════════════════════ */
      .fab-container {
        position: fixed; bottom: 1.25rem; right: 1.25rem; z-index: 100;
        display: flex; flex-direction: column; gap: 0.6rem; align-items: center;
      }
      @media (min-width: 768px) { .fab-container { bottom: 2rem; right: 2rem; gap: 0.75rem; } }

      .fab {
        position: relative; /* FIX: wajib ada agar ::after ter-positioning benar */
        overflow: visible; /* FIX: wajib visible agar pulse ring keluar */
        width: 46px; height: 46px; border-radius: 50%;
        background: rgba(24,24,27,0.75);
        border: 1px solid rgba(255,255,255,0.08);
        color: rgba(255,255,255,0.6);
        display: flex; align-items: center; justify-content: center;
        cursor: pointer;
        transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 0 4px 16px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.05);
        touch-action: manipulation;
        -webkit-tap-highlight-color: transparent;
      }
      @media (min-width: 768px) { .fab { width: 50px; height: 50px; } }

      .fab:hover {
        background: rgba(255,255,255,0.95);
        color: #09090b;
        border-color: rgba(255,255,255,0.3);
        box-shadow: 0 0 24px rgba(255,255,255,0.15), 0 8px 24px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.2);
        transform: translateY(-3px) scale(1.05);
      }
      .fab:active { transform: translateY(0) scale(0.96); }

      /* Back to top — state tersembunyi */
      .fab#back-to-top {
        opacity: 0; transform: translateY(16px) scale(0.85);
        pointer-events: none;
        transition: opacity 0.4s cubic-bezier(0.16,1,0.3,1), transform 0.4s cubic-bezier(0.16,1,0.3,1), background 0.35s, color 0.35s, border-color 0.35s, box-shadow 0.35s;
      }
      .fab#back-to-top.visible {
        opacity: 1; transform: translateY(0) scale(1); pointer-events: auto;
      }

      /* ═══════════════════════════════════════════════════════
         MUSIC PULSE — FIX: position: relative + overflow: visible
         + Double ring untuk efek lebih keren
      ═══════════════════════════════════════════════════════ */
      .fab#music-toggle.playing::before,
      .fab#music-toggle.playing::after {
        content: '';
        position: absolute;
        inset: -5px;
        border-radius: 50%;
        border: 1px solid rgba(255,255,255,0.35);
        pointer-events: none;
        z-index: -1;
      }
      .fab#music-toggle.playing::before {
        animation: fab-pulse-1 2s cubic-bezier(0.25, 0.46, 0.45, 0.94) infinite;
      }
      .fab#music-toggle.playing::after {
        animation: fab-pulse-2 2s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.6s infinite;
      }

      @keyframes fab-pulse-1 {
        0% { transform: scale(1); opacity: 0.6; }
        100% { transform: scale(1.8); opacity: 0; }
      }
      @keyframes fab-pulse-2 {
        0% { transform: scale(1); opacity: 0.4; }
        100% { transform: scale(2.2); opacity: 0; }
      }

